; --- Calcul de la factorielle 4*3*2[*1] ---
; R0 : Accumulateur (Résultat)
; R1 : Valeur à ajouter (le compteur qui descend) -> R1!
; R2 : Valeur d'arrêt (1)
; ############### 24 octets ################

; MOV R0, 1    (Initialise le résultat à 1)
11 00 01

; MOV R1, 4    (On commence à 4)
11 01 04

; MOV R2, 1    (On s'arrête quand on a ajouté toutes les valeurs jusqu'à 0)
11 02 01

; --- DEBUT BOUCLE (Adresse 0x09) ---
; MUL R0, R1   (R0 = R0 x R1)
26 00 01

; MOV R3, 1    (Valeur temporaire pour décrémenter)
11 03 01

; SUB R1, R3   (R1 = R1 - 1)
22 01 03

; CMP R1, R2   (Est-ce que le compteur R1 est arrivé à 1 ?)
28 01 02

; JNZ 09       (Si R1 n'est pas encore 1, on retourne au MUL à l'adresse 0x09)
42 09

; --- FIN ---
; HLT
FF